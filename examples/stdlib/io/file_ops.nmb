load io

path = "target/nimble_example_file_ops.txt"
lines = ["first line", "second line", "third line"]
out("ready to write")
io.write_lines(path, lines)?
out("done writing")
out("checking exists")
if io.exists(path):
    out("reading file")
    read = io.read_lines(path)?
    for line in read:
        out("line: {line}")
